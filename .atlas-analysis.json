  "keyFeatures": [
    "Multi-role access control (Admin/Enfermera, Doctor, TENS, Cuidadora)",
    "Resident management with medical profiles and allergy tracking",
    "Prescription and medication order management with scheduled doses",
    "Daily medication administration tracking (Administered, Omitted, Rejected, Pending)",
    "Inventory/stock management with configurable critical thresholds",
    "Telegram bot notifications for critical stock levels",
    "Monthly medication administration reports with PDF export",
    "Caregiver-to-resident assignment system",
    "Medication catalog with autocomplete from local, CIMA (AEMPS), and RxNorm APIs",
    "Android companion app (APK)"
  ],
  "publicApiSurface": [
    "GET /api/productos/suggest/?q=<query>&provider=LOCAL|CIMA|RXNORM|HYBRID",
    "GET /residentes/ — List residents",
    "POST /residentes/nuevo/ — Create resident",
    "GET /residentes/<id>/ — Resident detail",
    "POST /recetas/nueva/<residente_id>/ — Create prescription",
    "POST /orden/nueva/<receta_id>/ — Add medication order",
    "POST /administracion/quick/<admin_id>/ — Quick mark administration",
    "POST /administracion/grupo/ — Bulk mark administration group",
    "POST /orden/<id>/restock/ — Restock medication",
    "GET /registro/<residente_id>/?year=&month= — Monthly report",
    "GET /residentes/<id>/registro-mensual/pdf/ — Monthly report PDF",
    "GET/POST /asignaciones/ — Caregiver assignments",
    "POST /asignaciones/avisar-meds/ — Send Telegram medication alerts"
  ]
}
